APP_NAME="Gracimor LMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Africa/Lusaka

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=grassema
DB_USERNAME=grassema
DB_PASSWORD=

CACHE_DRIVER=file
QUEUE_CONNECTION=database
SESSION_DRIVER=file

# ── Email — Brevo (free 300/day) ─────────────────────────────────────────────
# Sign up at brevo.com → SMTP & API → Generate SMTP password
MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your-brevo-login@email.com   # Your Brevo account email
MAIL_PASSWORD=your-brevo-smtp-password     # SMTP key from Brevo dashboard
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@gracimor.co.zm"
MAIL_FROM_NAME="Gracimor Microfinance"

# ── Africa's Talking — SMS + WhatsApp (3-day & overdue reminders, confirmations) ──
# Sign up at africastalking.com → Dashboard → API Key
AT_USERNAME=sandbox
AT_API_KEY=your_at_api_key_here
AT_SENDER_ID=GRACIMOR               # Approved sender ID from AT dashboard
AT_SANDBOX=true                     # Set false in production
# WhatsApp: enable in AT dashboard → Applications → WhatsApp, then set product name here
AT_WA_PRODUCT=                      # e.g. GracimorLoans

GRASSEMA_COMPANY_NAME="Grassema Microfinance Ltd"
GRASSEMA_ADDRESS="Plot 12345, Cairo Road, Lusaka, Zambia"
GRASSEMA_OFFICE_PHONE="+260211000001"
GRASSEMA_EMAIL=info@grassema.co.zm
GRASSEMA_BOZ_LICENCE=MF/2019/001
GRASSEMA_TPIN=1000000000
GRASSEMA_COLLATERAL_RELEASE_DAYS=7

DAILY_REPORT_RECIPIENTS=

SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
