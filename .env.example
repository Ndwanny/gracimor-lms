APP_NAME="Gracimor LMS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.up.railway.app
APP_TIMEZONE=Africa/Lusaka

LOG_CHANNEL=stderr
LOG_LEVEL=error

# ── Database — copy values from Railway MySQL plugin's "Variables" tab ────────
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# ── Cache / Session — database driver survives container restarts ─────────────
CACHE_DRIVER=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=480

# ── Email — Brevo (free 300/day) ──────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your-brevo-login@email.com
MAIL_PASSWORD=your-brevo-smtp-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@gracimor.co.zm"
MAIL_FROM_NAME="Gracimor Microfinance"

# ── Twilio — SMS + WhatsApp reminders ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=+1XXXXXXXXXX
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Gracimor company config ───────────────────────────────────────────────────
GRACIMOR_COMPANY_NAME="Gracimor Microfinance Ltd"
GRACIMOR_ADDRESS="Plot 12345, Cairo Road, Lusaka, Zambia"
GRACIMOR_OFFICE_PHONE="+260211000001"
GRACIMOR_EMAIL=info@gracimor.co.zm
GRACIMOR_BOZ_LICENCE=MF/2019/001
GRACIMOR_TPIN=1000000000
GRACIMOR_COLLATERAL_RELEASE_DAYS=7

DAILY_REPORT_RECIPIENTS=

SANCTUM_STATEFUL_DOMAINS=your-app.up.railway.app
